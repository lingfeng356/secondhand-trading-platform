<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lingfeng.secondhandtradingplatform.mapper.OrderItemMapper">

    <!-- 批量查询订单商品 -->
    <select id="selectBatchByOrderIds" resultType="com.lingfeng.secondhandtradingplatform.pojo.OrderItem">
        select *
        from t_order_item
        where order_id in 
        <foreach collection="orderIds" item="orderId" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </select>
</mapper>